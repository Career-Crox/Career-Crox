
@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

:root{
  --bg: #f7ede4;
  --panel: rgba(255,255,255,0.96);
  --panel-2: #ffffff;
  --text: #1f2a44;
  --muted: #6e7a96;
  --line: #e7ebf3;
  --grad-1-a: #ffb36b;
  --grad-1-b: #f77f9b;
  --grad-2-a: #6db7ff;
  --grad-2-b: #5f7cff;
  --grad-3-a: #8b8cff;
  --grad-3-b: #b79cff;
  --grad-4-a: #73d9c8;
  --grad-4-b: #93d88f;
  --shadow-soft: 0 10px 30px rgba(31,42,68,0.08);
  --shadow-card: 0 8px 24px rgba(31,42,68,0.10);
  --radius-xl: 26px;
  --radius-lg: 20px;
  --radius-md: 16px;
  --radius-sm: 12px;
  --sidebar-w: 305px;
  --topbar-h: 92px;
  --sidebar-bg: linear-gradient(180deg, #fff2e7 0%, #fff8f1 32%, #eef6ff 100%);
  --app-bg: linear-gradient(180deg, #fff7f0 0%, #f6efe9 35%, #edf5ff 100%);
  --text-on-grad: #ffffff;
}

html[data-theme="ocean"]{
  --bg: #eef7ff; --panel: rgba(255,255,255,0.95); --text:#16334f; --muted:#507294; --line:#dbe9f7;
  --sidebar-bg: linear-gradient(180deg,#eff8ff,#eef3ff,#f2f9ff);
  --app-bg: linear-gradient(180deg,#eef7ff,#f5fbff);
  --grad-1-a:#79c8ff; --grad-1-b:#5e8cff; --grad-2-a:#46d0d9; --grad-2-b:#4d89ff; --grad-3-a:#8aa9ff; --grad-3-b:#b5a3ff; --grad-4-a:#7de7c4; --grad-4-b:#73d9c8;
}
html[data-theme="rose"]{
  --bg:#fff5f8; --panel:rgba(255,255,255,0.94); --text:#4a2141; --muted:#8a6079; --line:#f1dce5;
  --sidebar-bg: linear-gradient(180deg,#fff5f7,#fffafb,#fff3f5);
  --app-bg: linear-gradient(180deg,#fff5f8,#fffafd);
  --grad-1-a:#ff9fb6; --grad-1-b:#f77f9b; --grad-2-a:#ffb4c8; --grad-2-b:#b38dff; --grad-3-a:#ffa8de; --grad-3-b:#d39cff; --grad-4-a:#ffc27a; --grad-4-b:#ff9f8f;
}
html[data-theme="mint"]{
  --bg:#f3fffb; --panel:rgba(255,255,255,0.95); --text:#163e36; --muted:#4f7b72; --line:#d9efe7;
  --sidebar-bg: linear-gradient(180deg,#f4fffb,#f8fffd,#f2fff7);
  --app-bg: linear-gradient(180deg,#f3fffb,#f6fffd);
  --grad-1-a:#64e0c3; --grad-1-b:#6fc4ff; --grad-2-a:#8ce29b; --grad-2-b:#4bc7c1; --grad-3-a:#6bc7ff; --grad-3-b:#6e9dff; --grad-4-a:#89efb2; --grad-4-b:#74d9c7;
}
html[data-theme="sunset"]{
  --bg:#fff8f3; --panel:rgba(255,255,255,0.94); --text:#4b2d18; --muted:#8c6d56; --line:#f1dfd1;
  --sidebar-bg: linear-gradient(180deg,#fff6ef,#fffaf6,#fff2e8);
  --app-bg: linear-gradient(180deg,#fff8f3,#fffdf9);
  --grad-1-a:#ffb36b; --grad-1-b:#ff8a6e; --grad-2-a:#ffc857; --grad-2-b:#ff9e68; --grad-3-a:#ff9aa2; --grad-3-b:#ffb347; --grad-4-a:#ffca80; --grad-4-b:#ff8f70;
}
html[data-theme="lavender"]{
  --bg:#f8f6ff; --panel:rgba(255,255,255,0.94); --text:#332357; --muted:#72618e; --line:#e9e2fb;
  --sidebar-bg: linear-gradient(180deg,#fbf7ff,#f8f7ff,#f3f0ff);
  --app-bg: linear-gradient(180deg,#f8f6ff,#fcfbff);
  --grad-1-a:#b59cff; --grad-1-b:#8a8dff; --grad-2-a:#c5b4ff; --grad-2-b:#7ca0ff; --grad-3-a:#ffb0f0; --grad-3-b:#bf9cff; --grad-4-a:#95d8ff; --grad-4-b:#86c7ff;
}
html[data-theme="silver-pro"]{
  --bg:#f5f7fa; --panel:rgba(255,255,255,0.96); --text:#223041; --muted:#5e6e83; --line:#dfe5ed;
  --sidebar-bg: linear-gradient(180deg,#f7f8fa,#eef3f8,#f9fbfd);
  --app-bg: linear-gradient(180deg,#f4f7fa,#f8fafc);
  --grad-1-a:#92a8d1; --grad-1-b:#6b7fae; --grad-2-a:#8bc0ff; --grad-2-b:#7393d8; --grad-3-a:#b0b8c8; --grad-3-b:#8d9aad; --grad-4-a:#93c5c0; --grad-4-b:#7aa7ac;
}
html[data-theme="dark-pro"]{
  --bg:#111623; --panel:rgba(24,31,48,0.95); --panel-2:#161d2c; --text:#e7eefc; --muted:#9fb0cf; --line:#27324a;
  --sidebar-bg: linear-gradient(180deg,#151c2b,#0f1726,#171b29);
  --app-bg: linear-gradient(180deg,#0f1420,#131a28);
  --grad-1-a:#5f90ff; --grad-1-b:#8f7fff; --grad-2-a:#20c9c8; --grad-2-b:#3579ff; --grad-3-a:#a679ff; --grad-3-b:#6f93ff; --grad-4-a:#31c98a; --grad-4-b:#3bb2a7;
}
html[data-theme="dark-midnight"]{
  --bg:#0e1117; --panel:rgba(19,23,32,0.96); --panel-2:#131722; --text:#f2f5fb; --muted:#9aa7bf; --line:#232d3e;
  --sidebar-bg: linear-gradient(180deg,#121926,#0c111c,#161c29);
  --app-bg: linear-gradient(180deg,#0c1118,#101520);
  --grad-1-a:#3f7dff; --grad-1-b:#665eff; --grad-2-a:#2ec5ff; --grad-2-b:#2770ff; --grad-3-a:#7e71ff; --grad-3-b:#bf73ff; --grad-4-a:#19c891; --grad-4-b:#22b8d8;
}
html[data-theme="dark-vscode"]{
  --bg:#1e1e1e; --panel:rgba(37,37,38,0.97); --panel-2:#252526; --text:#f3f3f3; --muted:#b6b6b6; --line:#3b3b3b;
  --sidebar-bg: linear-gradient(180deg,#252526,#1f1f1f,#2a2a2a);
  --app-bg: linear-gradient(180deg,#1e1e1e,#252526);
  --grad-1-a:#007acc; --grad-1-b:#6a9cff; --grad-2-a:#2fb170; --grad-2-b:#0e8f6c; --grad-3-a:#c586c0; --grad-3-b:#8f6af5; --grad-4-a:#dcdcaa; --grad-4-b:#ce9178;
}

*{ box-sizing:border-box; margin:0; padding:0; }

html, body{
  width:100%; height:100%;
  font-family: "Plus Jakarta Sans", "Segoe UI", Arial, sans-serif;
  background: var(--app-bg);
  color: var(--text);
}
body{ overflow:hidden; }
body.login-body{ overflow:auto; }
a{ text-decoration:none; color:inherit; }
button, input, select, textarea{ font:inherit; }

.app-shell{ display:flex; width:100%; height:100vh; overflow:hidden; background:var(--app-bg); }

.sidebar{
  width: var(--sidebar-w); min-width: var(--sidebar-w);
  background: var(--sidebar-bg);
  border-right:1px solid rgba(231,235,243,0.65);
  padding:22px 18px; overflow-y:auto; box-shadow: inset -1px 0 0 rgba(0,0,0,0.02);
}
.brand-box{
  background: linear-gradient(135deg,var(--grad-1-a),var(--grad-1-b),var(--grad-2-a));
  border-radius: 24px; padding:20px 18px; color:var(--text-on-grad); box-shadow: var(--shadow-soft);
  margin-bottom:18px; position:relative; overflow:hidden;
}
.brand-box::after{
  content:""; position:absolute; right:-18px; bottom:-28px; width:130px; height:130px; border-radius:50%;
  background: rgba(255,255,255,0.12);
}
.brand-mini{ font-size:13px; font-weight:800; text-transform:uppercase; letter-spacing:.08em; margin-bottom:10px; }
.brand-title{ font-size:25px; font-weight:800; line-height:1.14; margin-bottom:10px; letter-spacing:-0.02em; }
.brand-sub{ font-size:13px; line-height:1.45; opacity:0.92; max-width:220px; }

.sidebar-nav{ display:flex; flex-direction:column; gap:10px; margin-top:8px; }
.nav-item{
  display:flex; align-items:center; padding:14px 16px; border-radius:16px; color:var(--text);
  font-size:15px; font-weight:700; transition:all 0.2s ease; border:1px solid transparent;
}
.nav-item:hover{ background: rgba(255,255,255,0.65); transform:translateX(3px) scale(1.01); }
.nav-item.active{
  background: linear-gradient(90deg, rgba(109,183,255,0.18), rgba(183,156,255,0.14));
  box-shadow: inset 0 0 0 1px rgba(109,183,255,0.18);
}

.theme-panel{
  margin-top:18px; background:rgba(255,255,255,0.62); border:1px solid rgba(231,235,243,0.8); border-radius:20px;
  padding:16px; box-shadow: var(--shadow-soft);
}
.theme-heading{ font-size:14px; font-weight:800; margin-bottom:12px; }
.theme-grid{ display:grid; grid-template-columns:repeat(5,1fr); gap:10px; }
.theme-dot{
  width:100%; aspect-ratio:1/1; border-radius:16px; border:2px solid rgba(255,255,255,0.8); cursor:pointer; transition: transform .16s ease;
  box-shadow: 0 6px 15px rgba(0,0,0,0.12);
}
.theme-dot:hover{ transform: translateY(-2px) scale(1.05); }
.theme-dot.theme-corporate-light{ background: linear-gradient(135deg,#ffb36b,#f77f9b,#6db7ff); }
.theme-dot.theme-ocean{ background: linear-gradient(135deg,#46d0d9,#4d89ff,#8aa9ff); }
.theme-dot.theme-rose{ background: linear-gradient(135deg,#ff9fb6,#f77f9b,#d39cff); }
.theme-dot.theme-mint{ background: linear-gradient(135deg,#64e0c3,#74d9c7,#8ce29b); }
.theme-dot.theme-sunset{ background: linear-gradient(135deg,#ffb36b,#ff8a6e,#ffc857); }
.theme-dot.theme-lavender{ background: linear-gradient(135deg,#b59cff,#8a8dff,#95d8ff); }
.theme-dot.theme-dark-pro{ background: linear-gradient(135deg,#5f90ff,#20c9c8,#31c98a); }
.theme-dot.theme-dark-midnight{ background: linear-gradient(135deg,#3f7dff,#665eff,#22b8d8); }
.theme-dot.theme-dark-vscode{ background: linear-gradient(135deg,#007acc,#2fb170,#c586c0); }
.theme-dot.theme-silver-pro{ background: linear-gradient(135deg,#92a8d1,#8bc0ff,#93c5c0); }
.theme-dot.active-theme{ outline:3px solid rgba(255,255,255,0.95); }
.theme-labels{ display:flex; justify-content:space-between; margin-top:10px; color:var(--muted); font-size:12px; font-weight:700; }

.main-wrap{ flex:1; display:flex; flex-direction:column; overflow:hidden; }
.topbar{
  height: var(--topbar-h); background: rgba(255,255,255,0.58); backdrop-filter: blur(14px);
  border-bottom:1px solid rgba(231,235,243,0.95); display:flex; align-items:center; justify-content:space-between;
  padding:18px 24px; gap:18px;
}
.topbar-left{ min-width:250px; }
.topbar-title{ font-size:18px; font-weight:800; color:var(--text); letter-spacing:-0.02em; }
.topbar-sub{ font-size:13px; color:var(--muted); margin-top:4px; }

.topbar-center{ flex:1; }
.search-box{
  width:100%; max-width:680px; min-height:54px; background:var(--panel); border:1px solid var(--line); border-radius:18px;
  display:flex; align-items:center; gap:12px; padding:6px; box-shadow: var(--shadow-soft);
}
.search-box input{
  flex:1; height:40px; border:none; outline:none; background:transparent; padding:0 12px; color:var(--text); font-size:15px;
}
.topbar-right{ display:flex; align-items:center; gap:12px; }
.add-profile-btn, .submit-btn, .ghost-btn, .top-pill{
  display:inline-flex; align-items:center; justify-content:center; gap:8px; border:none; cursor:pointer; text-decoration:none;
}
.add-profile-btn{
  min-height:48px; padding:0 20px; border-radius:16px; color:#fff; font-weight:800;
  background: linear-gradient(90deg, var(--grad-2-a), var(--grad-2-b)); box-shadow: 0 10px 24px rgba(95,124,255,0.28);
}
.top-pill{
  min-height:48px; padding:0 16px; border-radius:16px; background:var(--panel); border:1px solid var(--line); box-shadow:var(--shadow-soft); font-weight:700;
}
.pill-count{ min-width:22px; height:22px; padding:0 6px; border-radius:999px; background:linear-gradient(90deg,var(--grad-1-a),var(--grad-1-b)); color:#fff; font-size:12px; font-weight:800; display:inline-flex; align-items:center; justify-content:center; }
.user-chip{
  min-height:48px; padding:8px 14px; border-radius:16px; background:var(--panel); border:1px solid var(--line);
  box-shadow: var(--shadow-soft);
}
.user-name{ font-size:14px; font-weight:800; }
.user-role{ font-size:12px; color:var(--muted); margin-top:3px; }

.page-scroll{ flex:1; overflow:auto; padding:24px; }
.flash-stack{ display:flex; flex-direction:column; gap:10px; margin-bottom:18px; }
.flash{ padding:14px 16px; border-radius:16px; font-weight:700; border:1px solid var(--line); background:var(--panel); box-shadow:var(--shadow-soft); }
.flash.success{ border-color: rgba(58,184,136,.25);}
.flash.danger{ border-color: rgba(235,87,87,.25);}
.flash.info{ border-color: rgba(76,132,255,.25);}

.dashboard-grid{ display:grid; grid-template-columns: repeat(12,1fr); gap:20px; }
.stats-row, .action-row, .section-row, .bottom-two{ grid-column:1/-1; display:grid; gap:20px; }
.stats-row{ grid-template-columns:repeat(4,1fr); }
.action-row{ grid-template-columns:repeat(4,1fr); }
.section-row{ grid-template-columns:1.4fr 1fr 1fr; }
.bottom-two{ grid-template-columns:1.2fr 1fr; }

.stat-card{
  min-height:130px; border-radius:22px; padding:22px; color:#fff; position:relative; overflow:hidden; box-shadow:var(--shadow-card);
}
.stat-card::after{
  content:""; position:absolute; left:-30px; right:-30px; bottom:-44px; height:90px; background: rgba(255,255,255,0.12); border-radius:50%;
}
.stat-card.blue{ background:linear-gradient(135deg,var(--grad-2-a),var(--grad-2-b),var(--grad-1-b)); }
.stat-card.orange{ background:linear-gradient(135deg,var(--grad-1-a),var(--grad-1-b),#ff9b78); }
.stat-card.purple{ background:linear-gradient(135deg,var(--grad-3-a),var(--grad-3-b),var(--grad-2-a)); }
.stat-card.green{ background:linear-gradient(135deg,var(--grad-4-a),var(--grad-4-b),#d7d08d); }
.stat-label{ font-size:15px; font-weight:800; opacity:0.95; margin-bottom:12px; }
.stat-value{ font-size:40px; font-weight:800; line-height:1; }

.action-card{
  min-height:78px; border:none; border-radius:22px; padding:0 22px; color:#fff; font-size:18px; font-weight:800;
  display:flex; align-items:center; justify-content:space-between; box-shadow:var(--shadow-card); cursor:pointer; transition:transform 0.18s ease, box-shadow 0.18s ease;
}
.action-card:hover{ transform:translateY(-2px); }
.action-task{ background:linear-gradient(90deg,var(--grad-1-a),var(--grad-1-b)); }
.action-dialer{ background:linear-gradient(90deg,var(--grad-2-a),var(--grad-2-b)); }
.action-profiles{ background:linear-gradient(90deg,#7dc8ff,#72b2ff); }
.action-admin{ background:linear-gradient(90deg,#ffb36b,#ff9a6e); }

.panel{
  background: var(--panel); border:1px solid var(--line); border-radius:24px; box-shadow:var(--shadow-soft); padding:20px;
}
.panel-title{ font-size:22px; font-weight:800; color:var(--text); margin-bottom:16px; letter-spacing:-0.02em; }
.activity-list{ display:flex; flex-direction:column; gap:14px; }
.activity-item{
  display:flex; align-items:center; justify-content:space-between; gap:16px; padding:14px 16px; border-radius:16px;
  background: rgba(255,255,255,0.55); border:1px solid var(--line);
}
.activity-item.selected-item{ box-shadow: inset 0 0 0 1px rgba(109,183,255,0.22); background: rgba(109,183,255,0.08); }
.activity-left{ display:flex; flex-direction:column; gap:6px; }
.activity-name{ font-size:15px; font-weight:800; color:var(--text); }
.activity-sub{ font-size:13px; color:var(--muted); line-height:1.4; }
.badge, .status-chip{
  padding:8px 12px; border-radius:999px; font-size:12px; font-weight:800; border:1px solid transparent; white-space:nowrap;
}
.badge.pending, .status-chip{ background: rgba(76,132,255,0.10); color:#3671e9; }
.badge.closed{ background: rgba(255,179,107,0.14); color:#da8a17; }
.badge.active{ background: rgba(31,159,114,0.12); color:#1f9f72; }

.table-panel{
  background:var(--panel); border:1px solid var(--line); border-radius:24px; box-shadow:var(--shadow-soft); overflow:hidden;
}
.table-toolbar{
  display:flex; align-items:center; justify-content:space-between; gap:14px; padding:18px 20px; border-bottom:1px solid var(--line);
}
.table-toolbar.no-border{ border-bottom:none; padding:0 0 18px 0; }
.table-title{ font-size:22px; font-weight:800; color:var(--text); }
.subtle{ color:var(--muted); font-size:13px; margin-top:4px; }
.crm-table-wrap{ width:100%; overflow:auto; }
.crm-table{ width:100%; border-collapse:collapse; min-width:980px; }
.crm-table thead th{
  text-align:left; padding:16px 18px; font-size:12px; letter-spacing:0.06em; text-transform:uppercase; color:var(--muted);
  background: rgba(250,251,255,0.78); border-bottom:1px solid var(--line);
}
.crm-table tbody td{ padding:16px 18px; border-bottom:1px solid var(--line); color:var(--text); font-size:14px; font-weight:600; vertical-align:top; }
.crm-table tbody tr:hover{ background: rgba(255,255,255,0.48); }

.row-actions, .toolbar-actions{ display:flex; gap:8px; flex-wrap:wrap; }
.mini-btn{
  border:none; padding:9px 12px; border-radius:12px; font-size:13px; font-weight:800; cursor:pointer; display:inline-flex; align-items:center; justify-content:center;
}
.mini-btn.call{ background:#e8f1ff; color:#2f6fe7; }
.mini-btn.wa{ background:#e7fbf1; color:#159e67; }
.mini-btn.edit{ background:#fff4de; color:#d78a18; }
.mini-btn.view{ background:#f0edff; color:#6b5ae0; }

.form-panel{ background:var(--panel); border:1px solid var(--line); border-radius:24px; box-shadow:var(--shadow-soft); padding:22px; }
.field{ display:flex; flex-direction:column; gap:8px; margin-bottom:16px; }
.field label, .helper-text{ font-size:13px; font-weight:700; color:var(--muted); line-height:1.5; }
.field input, .field select, .field textarea, .note-form textarea, .chat-form textarea{
  width:100%; border:1px solid var(--line); background: rgba(251,252,255,0.85); border-radius:16px; padding:14px 15px; outline:none; font-size:15px; color:var(--text);
}
.note-form textarea, .chat-form textarea{ min-height:120px; resize:vertical; }
.submit-btn{
  margin-top:14px; min-height:52px; padding:0 22px; border-radius:16px; color:#fff; font-weight:800;
  background:linear-gradient(90deg,var(--grad-2-a),var(--grad-2-b)); box-shadow:0 10px 24px rgba(95,124,255,0.25);
}
.ghost-btn{
  min-height:44px; padding:0 16px; border-radius:14px; background:var(--panel); color:var(--text); border:1px solid var(--line); box-shadow:var(--shadow-soft);
}
.note-form, .chat-form{ display:flex; flex-direction:column; gap:12px; }

.detail-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
.detail-grid .wide{ grid-column:span 3; }
.info-grid{ display:grid; grid-template-columns:repeat(2,1fr); gap:14px; }
.info-grid div{ background: rgba(255,255,255,0.50); border:1px solid var(--line); border-radius:16px; padding:14px; }
.info-grid span{ display:block; font-size:12px; color:var(--muted); margin-bottom:6px; }
.info-grid strong{ font-size:14px; color:var(--text); }
.notes-list{ display:flex; flex-direction:column; gap:12px; }
.note-card{
  border:1px solid var(--line); border-radius:18px; padding:16px; background: rgba(255,255,255,0.55);
}
.note-card.private{ background: rgba(240,237,255,0.24); }
.note-meta{ font-size:12px; font-weight:800; color:var(--muted); margin-bottom:8px; }
.note-body{ font-size:14px; line-height:1.6; color:var(--text); white-space:pre-wrap; }
.hidden-note-stack{ display:none; margin-top:14px; flex-direction:column; gap:12px; }
.hidden-note-stack.show-all{ display:flex; }
.top-gap{ margin-top:16px; }

.kanban-grid{ display:grid; grid-template-columns:repeat(5,1fr); gap:18px; }
.kanban-col{ min-height:250px; }
.kanban-card{
  background: rgba(255,255,255,0.60); border:1px solid var(--line); border-radius:18px; padding:14px; margin-bottom:12px;
}
.mini-title{ font-size:15px; font-weight:800; margin-bottom:6px; }
.mini-sub{ font-size:13px; color:var(--muted); line-height:1.4; }
.mini-meta{ font-size:12px; color:var(--muted); margin-top:8px; }

.chat-layout, .small-grid.two, .preview-wrap{ display:grid; grid-template-columns:1fr 2fr; gap:20px; }
.small-grid.two{ grid-template-columns:1fr 1fr; }
.chat-window{
  min-height:350px; max-height:55vh; overflow:auto; display:flex; flex-direction:column; gap:12px; padding-right:4px; margin-bottom:16px;
}
.chat-bubble{
  max-width:75%; padding:14px 16px; border-radius:18px; background: rgba(255,255,255,0.55); border:1px solid var(--line);
}
.chat-bubble.mine{ align-self:flex-end; background: rgba(109,183,255,0.12); }
.bullet-grid{
  display:grid; grid-template-columns:repeat(2,1fr); gap:12px;
}
.bullet-grid > div, .mini-card{
  background: rgba(255,255,255,0.56); border:1px solid var(--line); border-radius:16px; padding:14px;
}
.doc-pre{
  white-space:pre-wrap; word-break:break-word; font-size:13px; line-height:1.55; color:var(--text); max-height:70vh; overflow:auto;
}
.login-wrap, .preview-wrap{
  max-width:1200px; margin:0 auto; padding:36px 20px; display:grid; grid-template-columns: 1fr 1.2fr; gap:24px;
}
.login-card{
  background:var(--panel); border:1px solid var(--line); border-radius:28px; box-shadow:var(--shadow-soft); padding:28px;
}
.login-card h1{ font-size:34px; font-weight:800; margin-bottom:10px; letter-spacing:-0.03em; }
.muted-copy{ color:var(--muted); line-height:1.6; margin-bottom:18px; }
.login-form{ display:flex; flex-direction:column; gap:8px; }
.login-side{ align-self:start; }
.mini-note{ color:var(--muted); font-size:12px; margin-top:12px; }

.bounceable{
  transition: transform .14s ease, box-shadow .14s ease;
}
.bounceable:hover{ transform: translateY(-2px) scale(1.02); }
.bounceable:active{ transform: translateY(1px) scale(0.96); }

@keyframes subtleBounce {
  0% { transform: scale(1); }
  30% { transform: scale(0.97); }
  65% { transform: scale(1.03); }
  100% { transform: scale(1); }
}
.theme-dot:active, .nav-item:active, .action-card:active, .add-profile-btn:active, .top-pill:active, .mini-btn:active {
  animation: subtleBounce .24s ease;
}

@media (max-width: 1400px){
  .section-row, .bottom-two { grid-template-columns:1fr; }
  .detail-grid{ grid-template-columns:1fr 1fr; }
  .detail-grid .wide{ grid-column:span 2; }
}
@media (max-width: 1220px){
  .stats-row, .action-row{ grid-template-columns:repeat(2,1fr); }
  .kanban-grid{ grid-template-columns:repeat(2,1fr); }
  .chat-layout, .small-grid.two, .login-wrap, .preview-wrap{ grid-template-columns:1fr; }
}
@media (max-width: 980px){
  .sidebar{ width:100px; min-width:100px; padding:16px 10px; }
  .brand-title, .brand-sub, .brand-mini, .theme-heading, .theme-labels, .nav-item{ font-size:0; }
  .nav-item{ min-height:48px; }
  .nav-item::after{ content:"•"; font-size:26px; color:var(--text); margin:auto; }
  .theme-grid{ grid-template-columns:repeat(2,1fr); }
  .topbar{ flex-wrap:wrap; height:auto; padding:14px 16px; }
  .topbar-left, .topbar-center, .topbar-right{ width:100%; }
  .stats-row, .action-row, .kanban-grid, .detail-grid{ grid-template-columns:1fr; }
  .detail-grid .wide{ grid-column:span 1; }
  .info-grid{ grid-template-columns:1fr; }
}
@media (max-width: 640px){
  .page-scroll{ padding:16px; }
  .topbar-right{ flex-wrap:wrap; }
  .search-box{ flex-direction:column; align-items:stretch; padding:10px; }
  .search-box input{ padding:10px 0; }
  .user-chip{ width:100%; }
  .bullet-grid{ grid-template-columns:1fr; }
}


.top-action-wrap{ position:relative; }
.add-menu{ position:absolute; top:58px; right:0; min-width:220px; background:var(--panel); border:1px solid var(--line); border-radius:18px; box-shadow:var(--shadow-soft); padding:10px; display:none; z-index:25; }
.add-menu.show{ display:block; }
.add-menu a{ display:block; padding:12px 14px; border-radius:14px; font-weight:800; margin-bottom:6px; background:linear-gradient(90deg, rgba(109,183,255,.08), rgba(247,127,155,.08)); }
.add-menu a:last-child{ margin-bottom:0; }
.impersonation-line{ font-size:11px; color:var(--muted); margin-top:2px; }
.page-accent-strip{ display:flex; justify-content:space-between; gap:14px; padding:14px 18px; border-radius:18px; color:#fff; font-weight:800; margin-bottom:16px; box-shadow:var(--shadow-soft); }
.candidate-strip{ background:linear-gradient(90deg,var(--grad-2-a),var(--grad-3-b)); }
.task-strip{ background:linear-gradient(90deg,var(--grad-1-a),var(--grad-1-b)); }
.interview-strip{ background:linear-gradient(90deg,var(--grad-3-a),var(--grad-2-b)); }
.admin-strip{ background:linear-gradient(90deg,var(--grad-4-a),var(--grad-2-b)); }
.colorful-table thead th{ background:linear-gradient(90deg, rgba(109,183,255,.14), rgba(247,127,155,.12), rgba(115,217,200,.12)); }
.priority-pill{ display:inline-flex; padding:8px 12px; border-radius:999px; font-size:12px; font-weight:800; background:rgba(109,183,255,.12); color:#315fd8; }
.priority-low{ background:rgba(115,217,200,.14); color:#16785f; }
.priority-medium{ background:rgba(255,179,107,.16); color:#b96b07; }
.priority-high{ background:rgba(247,127,155,.16); color:#c43d66; }
.stage-tabs{ display:flex; gap:10px; flex-wrap:wrap; margin-bottom:16px; }
.stage-tab{ padding:12px 16px; border-radius:14px; border:1px solid var(--line); background:var(--panel); box-shadow:var(--shadow-soft); font-weight:800; }
.stage-tab.active{ color:#fff; background:linear-gradient(90deg,var(--grad-2-a),var(--grad-2-b)); }
.module-actions-grid{ grid-template-columns:repeat(4,1fr); }
.top-gap-small{ margin-top:14px; }
.inline-form{ display:flex; gap:12px; align-items:center; flex-wrap:wrap; }
.inline-input{ min-width:320px; border:1px solid var(--line); background: rgba(251,252,255,0.85); border-radius:16px; padding:14px 15px; outline:none; font-size:15px; color:var(--text); }
@media (max-width: 1220px){ .module-actions-grid{ grid-template-columns:repeat(2,1fr);} }
@media (max-width: 640px){ .module-actions-grid{ grid-template-columns:1fr;} .page-accent-strip{ flex-direction:column; } .add-menu{ left:0; right:auto; } }


/* === V3 Gen-Z premium patch === */
.topbar{position:relative; z-index:50;}
.page-scroll{position:relative; z-index:1;}
.glassy-card{backdrop-filter: blur(16px); background: color-mix(in srgb, var(--panel) 85%, transparent);}
.top-action-wrap{position:relative; z-index:120;}
.add-menu{top:58px; right:0; min-width:240px; z-index:9999; background:color-mix(in srgb, var(--panel) 94%, transparent); border:1px solid var(--line); box-shadow:0 22px 60px rgba(17,21,35,.18);} 
.add-menu a{display:block; margin:6px 0; color:var(--text);}
.compact-toolbar{padding:14px 18px;}
.filter-bar{display:flex; gap:10px; flex-wrap:wrap; align-items:center;}
.inline-input{min-height:42px; border:1px solid var(--line); border-radius:14px; background:rgba(255,255,255,.75); color:var(--text); padding:0 14px; min-width:180px;}
.bulk-dialer{display:none; align-items:center; justify-content:space-between; gap:14px; margin-top:14px; padding:14px 16px; border:1px solid var(--line); border-radius:22px; box-shadow:var(--shadow-soft); background:linear-gradient(135deg, color-mix(in srgb, var(--grad-2-a) 14%, transparent), color-mix(in srgb, var(--grad-3-b) 10%, transparent));}
.bulk-dialer.show{display:flex;}
.inline-subtle{margin-left:8px;}
.slim-bulk{display:flex;}
.mini-chip{display:inline-flex; align-items:center; padding:8px 12px; border-radius:999px; background:rgba(255,255,255,.65); border:1px solid var(--line); font-size:12px; font-weight:800;}
.mini-chip.soft{background:rgba(109,183,255,.12);}
.compact-pills{align-items:center;}
.dense-wrap{overflow:auto;}
.dense-table{min-width:1180px; table-layout:fixed;}
.dense-table thead th{padding:12px 12px; font-size:11px; background:linear-gradient(90deg, rgba(109,183,255,.08), rgba(247,127,155,.06), rgba(115,217,200,.06)); white-space:nowrap;}
.dense-table tbody td{padding:10px 12px; font-size:13px; line-height:1.25;}
.dense-table tbody tr{height:54px;}
.selected-row{background:color-mix(in srgb, var(--grad-2-a) 10%, transparent) !important;}
.tiny-meta{font-size:11px; color:var(--muted); margin-top:4px;}
.nowrap-actions{flex-wrap:nowrap;}
.icon-actions{display:flex; gap:8px; align-items:center;}
.icon-btn{width:38px; height:38px; border-radius:12px; display:inline-flex; align-items:center; justify-content:center; font-size:18px; font-weight:800; box-shadow:var(--shadow-soft);}
.icon-btn.call{background:#e8f1ff; color:#2f6fe7;}
.icon-btn.wa{background:#e7fbf1; color:#159e67;}
.icon-btn.edit{background:#fff4de; color:#d78a18;}
.icon-btn.view{background:#f0edff; color:#6b5ae0;}
.sticky-action-col,.sticky-actions-cell{position:sticky; right:0; z-index:3; background:color-mix(in srgb, var(--panel) 96%, transparent);} 
.dense-table .sticky-actions-cell{padding-right:18px;}
.drag-col{width:56px;}
.floating-dialer{display:none; position:fixed; right:24px; bottom:24px; width:min(520px, calc(100vw - 48px)); padding:18px; border:1px solid var(--line); border-radius:26px; box-shadow:0 28px 80px rgba(17,21,35,.24); z-index:150; background:color-mix(in srgb, var(--panel) 92%, transparent);} 
.floating-dialer.show{display:block; animation: popIn .28s ease;}
@keyframes popIn{from{transform:translateY(18px) scale(.96); opacity:0;} to{transform:translateY(0) scale(1); opacity:1;}}
.dialer-head{display:flex; justify-content:space-between; gap:14px; align-items:flex-start; margin-bottom:12px;}
.dialer-title{margin:0; font-size:20px;}
.dialer-now{padding:16px; border-radius:18px; background:linear-gradient(135deg, color-mix(in srgb, var(--grad-2-a) 18%, transparent), color-mix(in srgb, var(--grad-1-b) 12%, transparent)); border:1px solid var(--line); font-size:16px; font-weight:700; margin-bottom:14px;}
.dialer-timer{width:80px; height:80px; border-radius:50%; display:grid; place-items:center; font-size:28px; font-weight:800; color:#fff; background:linear-gradient(135deg,var(--grad-1-a),var(--grad-2-b)); box-shadow:var(--shadow-card); margin-bottom:14px;}
.dialer-actions-row{gap:10px; margin-bottom:12px;}
.crm-table tbody tr:hover{background:color-mix(in srgb, var(--grad-2-a) 6%, transparent);} 
.page-accent-strip{display:flex; justify-content:space-between; gap:14px; padding:12px 18px; margin-bottom:14px; border-radius:18px; color:#fff; font-weight:800; background:linear-gradient(90deg,var(--grad-2-a),var(--grad-2-b),var(--grad-3-b)); box-shadow:var(--shadow-soft);} 
.mini-stats-row{grid-template-columns:repeat(4,1fr); gap:16px;}
.mini-stat-box{padding:18px; border-radius:22px; border:1px solid var(--line); background:color-mix(in srgb, var(--panel) 90%, transparent); box-shadow:var(--shadow-soft);} 
.mini-stat-box span{display:block; font-size:12px; font-weight:800; color:var(--muted); margin-bottom:8px;}
.mini-stat-box strong{font-size:24px;}
.glow-box{position:relative; overflow:hidden;}
.glow-box::before{content:""; position:absolute; inset:auto -30% -70% auto; width:180px; height:180px; background:radial-gradient(circle, rgba(255,255,255,.28), transparent 60%);}
.compact-action-grid{grid-template-columns:repeat(4,1fr);} 
.platform-tabs .stage-tabs, .compact-stage-tabs{display:flex; gap:10px; flex-wrap:wrap;}
.stage-tab{display:inline-flex; align-items:center; justify-content:center; min-height:44px; padding:0 16px; border-radius:16px; background:var(--panel); border:1px solid var(--line); box-shadow:var(--shadow-soft); font-weight:800;}
.stage-tab.active{background:linear-gradient(90deg,var(--grad-2-a),var(--grad-2-b)); color:#fff;}
.priority-pill{display:inline-flex; padding:8px 12px; border-radius:999px; font-size:12px; font-weight:800; background:rgba(183,156,255,.16); color:#4d63ea;}
.priority-pill.priority-high{background:rgba(255,132,132,.14); color:#d54b4b;}
.priority-pill.priority-medium{background:rgba(255,183,107,.16); color:#cb7f18;}
.priority-pill.priority-low{background:rgba(115,217,200,.16); color:#118b72;}
.demo-modal-shell{position:fixed; inset:0; background:rgba(7,10,18,.35); display:none; align-items:center; justify-content:center; z-index:200; padding:20px;}
.demo-modal-shell.show{display:flex;}
.demo-modal{width:min(560px, 100%); padding:22px; border:1px solid var(--line); border-radius:28px; box-shadow:0 30px 90px rgba(7,10,18,.28);}
.demo-modal-top{display:flex; align-items:center; justify-content:space-between; gap:14px; margin-bottom:16px;}
.bounce-pulse-target{animation: pulseGentle 1.6s ease infinite;}
@keyframes pulseGentle{0%,100%{box-shadow:0 12px 32px rgba(31,42,68,.08);}50%{box-shadow:0 18px 44px color-mix(in srgb, var(--grad-1-b) 18%, transparent);}}
html[data-theme="ocean"] .app-shell, html[data-theme="ocean"] body{background:linear-gradient(180deg,#e8f6ff,#eff9ff,#f4fcff);} 
html[data-theme="rose"] .app-shell, html[data-theme="rose"] body{background:linear-gradient(180deg,#fff1f6,#fff6fb,#fffaff);} 
html[data-theme="mint"] .app-shell, html[data-theme="mint"] body{background:linear-gradient(180deg,#effff9,#f5fffb,#fbfffd);} 
html[data-theme="sunset"] .app-shell, html[data-theme="sunset"] body{background:linear-gradient(180deg,#fff4eb,#fff8f1,#fffdf9);} 
html[data-theme="lavender"] .app-shell, html[data-theme="lavender"] body{background:linear-gradient(180deg,#f7f3ff,#faf8ff,#fdfcff);} 
html[data-theme="silver-pro"] .app-shell, html[data-theme="silver-pro"] body{background:linear-gradient(180deg,#f1f5f9,#f7fafc,#fcfdff);} 
@media (max-width: 1200px){ .compact-action-grid{grid-template-columns:repeat(2,1fr);} .mini-stats-row{grid-template-columns:repeat(2,1fr);} }
@media (max-width: 820px){ .bulk-dialer,.dialer-actions-row,.filter-bar{flex-direction:column; align-items:stretch;} .floating-dialer{right:12px; left:12px; width:auto;} .compact-action-grid,.mini-stats-row{grid-template-columns:1fr;} }


/* Career Crox premium branding additions */
.brand-logo-row{ display:flex; align-items:center; gap:14px; margin-bottom:12px; position:relative; z-index:1; }
.brand-logo-icon{ width:58px; height:58px; object-fit:contain; filter: drop-shadow(0 8px 18px rgba(17,66,140,0.18)); }
.brand-wordmark{ font-size:24px; font-weight:800; line-height:1; letter-spacing:-0.03em; }
.topbar-brand-title{ display:flex; align-items:center; gap:10px; }
.topbar-logo{ width:34px; height:34px; object-fit:contain; filter: drop-shadow(0 4px 10px rgba(17,66,140,0.14)); }
.lux-hero{ grid-column:1/-1; display:grid; grid-template-columns:1.1fr .9fr; gap:24px; align-items:center; padding:26px 28px; overflow:hidden; position:relative; background: linear-gradient(135deg, rgba(255,179,107,0.96), rgba(247,127,155,0.96), rgba(109,183,255,0.96)); color:#fff; box-shadow: 0 18px 40px rgba(80,88,130,0.18); }
.lux-hero::after{ content:""; position:absolute; right:-70px; top:-70px; width:240px; height:240px; border-radius:50%; background:rgba(255,255,255,0.16); }
.lux-hero-copy, .lux-hero-brand{ position:relative; z-index:1; }
.lux-hero-kicker{ font-size:13px; font-weight:800; letter-spacing:.16em; opacity:.95; margin-bottom:10px; }
.lux-hero-title{ font-size:48px; line-height:1.02; letter-spacing:-0.04em; margin-bottom:14px; max-width:620px; }
.lux-hero-sub{ font-size:16px; line-height:1.6; max-width:650px; opacity:.96; }
.lux-hero-tags{ display:flex; flex-wrap:wrap; gap:10px; margin-top:18px; }
.lux-hero-tags span{ padding:10px 14px; border-radius:999px; background:rgba(255,255,255,0.16); border:1px solid rgba(255,255,255,0.24); font-size:13px; font-weight:800; }
.lux-hero-brand{ display:flex; justify-content:flex-end; }
.lux-hero-brand img{ width:min(100%, 470px); height:auto; object-fit:contain; filter: drop-shadow(0 14px 30px rgba(90,39,4,0.14)); }
.login-brand-head{ margin-bottom:16px; }
.login-logo{ width:min(100%, 420px); height:auto; display:block; }
.login-card h1{ font-size:42px; line-height:1.02; letter-spacing:-0.04em; margin-bottom:10px; }
.login-card .brand-mini{ margin-bottom:8px; }
@media (max-width: 1100px){ .lux-hero{grid-template-columns:1fr;} .lux-hero-brand{justify-content:flex-start;} .lux-hero-title{font-size:40px;} }
@media (max-width: 820px){ .lux-hero{padding:22px 20px;} .lux-hero-title{font-size:34px;} .brand-wordmark{font-size:20px;} .brand-logo-icon{width:48px;height:48px;} .topbar-logo{width:28px;height:28px;} }


/* Professional login and branding refinements */
.login-card-pro{max-width:640px;}
.login-side-pro{min-width:320px;}
.password-wrap{display:flex; align-items:center; gap:10px;}
.password-wrap input{flex:1;}
.password-toggle{min-width:82px; height:48px; border:none; border-radius:14px; background:rgba(255,255,255,.9); border:1px solid var(--line); font-weight:800; cursor:pointer;}
.login-logo{max-width:460px;}
.brand-logo-icon{width:64px;height:64px;border-radius:14px;background:#fff;padding:4px;}
.topbar-logo{width:38px;height:38px;border-radius:10px;background:#fff;padding:2px;}
.lux-hero-brand img{max-width:520px;}
.panel-title{line-height:1.15;}
